# =============================================================================
#  SPIRENS — direnv configuration (contributors only)
# =============================================================================
#  Normal users don't need direnv — just `pip install .` from the repo root.
#  This file auto-bootstraps a complete dev environment when you `cd` into
#  the repo, using asdf for Python version management and uv for fast
#  dependency installation.
#
#  Prerequisites: direnv, asdf (with python plugin), uv
# =============================================================================

# ─── asdf ────────────────────────────────────────────────────────────────────
# Source asdf from whichever path it lives at.
for p in \
    /opt/homebrew/opt/asdf/libexec/asdf.sh \
    /usr/local/opt/asdf/libexec/asdf.sh \
    "${HOME}/.asdf/asdf.sh"; do
    if [ -f "$p" ]; then
        # shellcheck source=/dev/null
        source "$p"
        break
    fi
done

# Install the Python version pinned in .tool-versions if missing.
asdf install

# ─── venv (via uv) ──────────────────────────────────────────────────────────
VENV_DIR="${PWD}/.venv"

if [ ! -d "${VENV_DIR}" ]; then
    log_status "creating venv with uv..."
    uv venv "${VENV_DIR}"
fi

export VIRTUAL_ENV="${VENV_DIR}"
PATH_add "${VENV_DIR}/bin"

# ─── dependencies ────────────────────────────────────────────────────────────
# Stamp file avoids re-running uv pip install on every shell.
STAMP="${VENV_DIR}/.deps-installed"
DEPS_HASH="$(cat pyproject.toml requirements.txt 2>/dev/null | shasum -a 256 | cut -d' ' -f1)"

if [ ! -f "${STAMP}" ] || [ "$(cat "${STAMP}")" != "${DEPS_HASH}" ]; then
    log_status "installing dependencies (dev + docs)..."
    uv pip install -e ".[dev,docs]" --quiet
    printf '%s' "${DEPS_HASH}" > "${STAMP}"
fi

# ─── pre-commit hooks ───────────────────────────────────────────────────────
if [ -d .git ] && [ ! -f .git/hooks/pre-commit ]; then
    if command -v pre-commit > /dev/null 2>&1; then
        log_status "installing pre-commit hooks..."
        pre-commit install --install-hooks -q
    else
        log_status "pre-commit not found — install with: uv tool install pre-commit"
    fi
fi

# ─── summary ─────────────────────────────────────────────────────────────────
log_status "python:  $(python --version 2>&1 | head -1)"
log_status "venv:    ${VENV_DIR}"
log_status "spirens: $(spirens --version 2>/dev/null || echo 'not yet installed')"
