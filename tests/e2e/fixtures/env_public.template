# SPIRENS .env — public profile (80/443 reachable from the internet)
# Rendered by tests/e2e/harness/fixtures.py during E2E.

DEPLOYMENT_PROFILE=public

BASE_DOMAIN=${BASE_DOMAIN}
ACME_EMAIL=${ACME_EMAIL}

# E2E uses LE staging CA to avoid the 5-certs-per-identifier-per-week
# prod rate limit. Flip to https://acme-v02.api.letsencrypt.org/directory
# for a production-certificate pass (rare — staging is usually what you
# want for harness runs).
ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# DNS provider — we always test against Cloudflare in E2E.
DNS_PROVIDER=cloudflare
CF_API_EMAIL=${CF_API_EMAIL}
CF_DNS_API_TOKEN=${CF_DNS_API_TOKEN}

# Hostnames (derived from BASE_DOMAIN)
TRAEFIK_DASHBOARD_HOST=traefik.${BASE_DOMAIN}
ERPC_HOST=rpc.${BASE_DOMAIN}
IPFS_GATEWAY_HOST=ipfs.${BASE_DOMAIN}
DWEB_ETH_HOST=eth.${BASE_DOMAIN}
DWEB_RESOLVER_HOST=ens-resolver.${BASE_DOMAIN}

# Upstreams
ETH_LOCAL_URL=${ETH_LOCAL_URL}

# Redis password is auto-generated by `spirens bootstrap` if empty.
REDIS_PASSWORD=

# Public-profile: declare which records DDNS should track. Left empty by
# default so phase 06 can lay records down manually; phase 14 toggles
# this on to exercise the DDNS module itself.
DDNS_RECORDS=
PUBLIC_IP=${PUBLIC_IP}
DNS_SYNC_INTERVAL=one-shot
