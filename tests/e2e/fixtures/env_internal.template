# SPIRENS .env — internal profile (no inbound 80/443)
# Rendered by tests/e2e/harness/fixtures.py during E2E.

DEPLOYMENT_PROFILE=internal

BASE_DOMAIN=${BASE_DOMAIN}
ACME_EMAIL=${ACME_EMAIL}

# DNS provider — we always test against Cloudflare in E2E.
DNS_PROVIDER=cloudflare
CF_API_EMAIL=${CF_API_EMAIL}
CF_DNS_API_TOKEN=${CF_DNS_API_TOKEN}

# Hostnames (derived from BASE_DOMAIN)
TRAEFIK_DASHBOARD_HOST=traefik.${BASE_DOMAIN}
ERPC_HOST=rpc.${BASE_DOMAIN}
IPFS_GATEWAY_HOST=ipfs.${BASE_DOMAIN}
DWEB_ETH_HOST=eth.${BASE_DOMAIN}
DWEB_RESOLVER_HOST=ens-resolver.${BASE_DOMAIN}

# Upstreams — only the local node is exercised in E2E by default.
ETH_LOCAL_URL=${ETH_LOCAL_URL}

# Redis password is auto-generated by `spirens bootstrap` if empty.
REDIS_PASSWORD=

# DDNS records — left empty on internal profile (no public IP to track).
DDNS_RECORDS=
PUBLIC_IP=
DNS_SYNC_INTERVAL=300
