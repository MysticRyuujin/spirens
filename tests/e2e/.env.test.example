# SPIRENS live-VM E2E harness — copy to .env.test and fill in values.
# This file is gitignored.

# Target VM — host is DNS-resolvable (preferred for SSH); IP is how the
# workstation actually reaches the VM (LAN IP for internal testing, public
# IP for public testing where the VM is directly on the internet).
SPIRENS_TEST_HOST=test01.example.com
SPIRENS_TEST_IP=192.168.1.10
SPIRENS_TEST_USER=root

# Deployment profile: internal or public. Determines which .env fixture
# is rendered and which phases run (see tests/e2e/phases/pNN_*.py headers).
SPIRENS_TEST_PROFILE=internal

# Public IP the CF A records should point at. Leave empty for internal.
# On public profile with a NAT'd VM, set this to the router's external IP;
# without NAT, leave empty and the harness falls back to SPIRENS_TEST_IP.
SPIRENS_TEST_PUBLIC_IP=

# Domain that owns the Cloudflare zone (fresh — NS records only)
SPIRENS_TEST_DOMAIN=example.com
SPIRENS_TEST_ACME_EMAIL=mysticryuujin@protonmail.com

# Reachable LAN Ethereum node — leave empty to skip the local-upstream path
SPIRENS_TEST_ETH_LOCAL_URL=http://192.168.1.50:8545

# Cloudflare — scoped token with Zone.DNS:Edit on the test zone
CF_API_EMAIL=mysticryuujin@protonmail.com
CF_DNS_API_TOKEN=
