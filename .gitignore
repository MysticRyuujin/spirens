# Environment — contains CF token, Ethereum URLs, etc.
.env
.env.local
.env.*.local

# Secrets — bcrypt hashes, API tokens, ACME state, JWT secrets.
/secrets/
secrets/*
!secrets/.gitkeep

# Runtime state
/letsencrypt/
/data/

# Generated
/*.log
/site/
/config/erpc/erpc.generated.yaml

# Python
.venv/
*.egg-info/
dist/
build/
.direnv/

# Tool caches
.ruff_cache/
.mypy_cache/
.pytest_cache/
__pycache__/
node_modules/
.pre-commit-cache/

# Claude Code
.claude/settings.local.json
.claude/worktrees/
.claude/agents/

# E2E harness state
/tests/e2e/.env.test
/tests/e2e/report/logs/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
